<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ZynAddSubFX-data>
<ZynAddSubFX-data version-major="1" version-minor="0">
  <INSTRUMENT>
    <INFO>
      <string name="name">AQ Pad Harmonic</string>
      <string name="author">AquariumSynthCSharp tests</string>
      <string name="comments">Project-authored PAD fixture with explicit oscillator harmonics.</string>
      <par name="type" value="0"/>
    </INFO>
    <INSTRUMENT_KIT>
      <INSTRUMENT_KIT_ITEM id="0">
        <par_bool name="enabled" value="yes"/>
        <string name="name">Harmonic PAD</string>
        <par_bool name="pad_enabled" value="yes"/>
        <PAD_SYNTH_PARAMETERS>
          <OSCIL>
            <HARMONICS>
              <HARMONIC id="1">
                <par name="mag" value="127"/>
                <par name="phase" value="64"/>
              </HARMONIC>
              <HARMONIC id="2">
                <par name="mag" value="104"/>
                <par name="phase" value="64"/>
              </HARMONIC>
              <HARMONIC id="3">
                <par name="mag" value="88"/>
                <par name="phase" value="64"/>
              </HARMONIC>
            </HARMONICS>
          </OSCIL>
          <AMPLITUDE_PARAMETERS>
            <AMPLITUDE_ENVELOPE>
              <par_bool name="free_mode" value="yes"/>
            </AMPLITUDE_ENVELOPE>
          </AMPLITUDE_PARAMETERS>
        </PAD_SYNTH_PARAMETERS>
      </INSTRUMENT_KIT_ITEM>
    </INSTRUMENT_KIT>
  </INSTRUMENT>
</ZynAddSubFX-data>
